polygons begin
  a4_area
  local_dict_size dict begin
    25 625 translate
    (For the 3x{7/2} you will need:) tline
    (  * a total of six heptagrams.) tline
    (  * a total of 34 equilateral triangles:) tline
    (      - three times eleven that are originally from the three antiprisms) tline
    (      - one of the kind that is shared and these are found on page 2) tline
    (In this document I assumed using four colours as follows:) tline
    (All faces belonging to one of the three original antiprisms in one colour,) tline
    (and the one triangles that is shared in the fourth colour. This means:) tline
    (  * use page 3 and 4 once for colour 1, 2, and 3.) tline
    (  * use page 2 once for colour 4.) tline
    showpage
  end % local dict
end % polygons
%%EndPage

